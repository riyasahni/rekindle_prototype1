# Required: hosted Postgres (free). Get a URL in ~2 min: https://neon.tech → Create project → copy URI
# Or Supabase: Project Settings → Database → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Optional: Vercel Blob for image uploads (recommended for production).
# If omitted, photos are stored as base64 in Postgres (max ~2MB per image).
# Vercel → Project → Storage → Blob → create token
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# OpenAI — embeddings + short cluster labels (gpt-4o-mini)
OPENAI_API_KEY="sk-..."

# Facilitator: required to create boards via POST /api/boards and to list boards (GET /api/boards with Bearer).
# Participants do not need this — they scan the QR / open /b/your-slug and enter a name.
HOST_SECRET="choose-a-long-random-string"
